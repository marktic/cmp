{
    "name": "marktic/cmp",
    "description": "Server-side Consent Mode management system for SaaS applications. Records, audits and queries user consent for Google Consent Mode categories in multi-tenant environments.",
    "type": "library",
    "keywords": [
        "consent",
        "consent-mode",
        "google-consent-mode",
        "gdpr",
        "saas",
        "multi-tenant"
    ],
    "homepage": "https://github.com/marktic/cmp",
    "license": "MIT",
    "authors": [
        {
            "name": "Marktic",
            "homepage": "https://github.com/marktic"
        }
    ],
    "require": {
        "ext-json": "*",
        "bytic/package-base": "^1.0",
        "bytic/actions": "dev-main|^1.0|^2.0",
        "bytic/migrations": "~0.13",
        "bytic/orm": "^0.9|^1.0|^2.0",
        "bytic/orm-behaviors": "^0.9|^1.0|^2.0"
    },
    "require-dev": {
        "bytic/phpqatools": "^1.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Marktic\\Cmp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marktic\\Cmp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "ergebnis/composer-normalize": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "bytic/phpqatools": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
